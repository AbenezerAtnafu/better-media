{
  "name": "better-media-example-express",
  "version": "1.0.2",
  "private": true,
  "description": "Express example integrating Better Media framework",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@better-media/adapter-db": "workspace:*",
    "@better-media/adapter-storage-filesystem": "workspace:*",
    "@better-media/adapter-storage-memory": "workspace:*",
    "@better-media/adapter-storage-s3": "workspace:*",
    "@better-media/plugin-media-processing": "workspace:*",
    "@better-media/plugin-validation": "workspace:*",
    "@better-media/plugin-virus-scan": "workspace:*",
    "@better-media/framework": "workspace:*",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
