{
  "name": "better-media",
  "version": "1.0.0",
  "private": true,
  "description": "Better Media - modular media pipeline framework",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency 12",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "coverage": "turbo run test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "abenezeratnafu",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "eslint": "^9.39.4",
      "handlebars": "^4.7.9",
      "multer": "^2.1.1",
      "lodash": "^4.18.0",
      "picomatch": "^4.0.4",
      "glob": "^10.5.0",
      "ajv": "^8.18.0",
      "webpack": "^5.104.1",
      "tmp": "^0.2.4"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
