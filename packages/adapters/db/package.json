{
  "name": "@better-media/adapter-db",
  "version": "1.0.0",
  "description": "Database adapter interfaces and implementations for Better Media",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./kysely": {
      "types": "./dist/adapters/kysely/index.d.ts",
      "import": "./dist/adapters/kysely/index.mjs",
      "require": "./dist/adapters/kysely/index.js"
    },
    "./mongodb": {
      "types": "./dist/adapters/mongodb/index.d.ts",
      "import": "./dist/adapters/mongodb/index.mjs",
      "require": "./dist/adapters/mongodb/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@better-media/core": "workspace:*",
    "better-media": "workspace:*",
    "@better-media/mongodb-adapter": "workspace:*"
  },
  "peerDependencies": {
    "kysely": "^0.27.0 || ^0.28.0",
    "mongodb": "^6.8.0"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/mongodb": "^4.0.7",
    "@types/pg": "^8.11.10",
    "kysely": "^0.28.14",
    "mongodb": "^6.8.0",
    "@types/node": "^22.10.0"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0"
}
