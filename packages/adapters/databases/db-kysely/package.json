{
  "name": "@better-media/adapter-db-kysely",
  "version": "0.3.0",
  "description": "Kysely SQL database adapter for Better Media",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@better-media/core": "workspace:*",
    "kysely": "^0.27.0 || ^0.28.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/pg": "^8.11.10",
    "@types/node": "^22.10.0",
    "jest": "^30.2.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "better-media",
    "database",
    "kysely",
    "sql",
    "adapter"
  ],
  "author": "Abenezer Atnafu",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbenezerAtnafu/better-media.git"
  },
  "homepage": "https://better-media-platform.vercel.app/",
  "bugs": {
    "url": "https://github.com/AbenezerAtnafu/better-media/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
