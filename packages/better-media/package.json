{
  "name": "@better-media/framework",
  "version": "0.2.0",
  "description": "Better Media - media pipeline framework runtime",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "media": "./bin/media.mjs",
    "better-media": "./bin/media.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@better-media/adapter-jobs": "workspace:*",
    "@better-media/cli": "workspace:*",
    "@better-media/core": "workspace:*"
  },
  "keywords": [],
  "author": "Abenezer Atnafu",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbenezerAtnafu/better-media.git"
  },
  "homepage": "https://better-media-platform.vercel.app/",
  "bugs": {
    "url": "https://github.com/AbenezerAtnafu/better-media/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
