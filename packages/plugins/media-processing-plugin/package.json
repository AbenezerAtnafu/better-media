{
  "name": "@better-media/plugin-media-processing",
  "version": "0.3.0",
  "description": "Media processing plugin for Better Media pipeline",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@better-media/core": "workspace:*"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@better-media/adapter-db-memory": "workspace:*",
    "@better-media/adapter-storage-memory": "workspace:*",
    "@types/jest": "^29.5.14",
    "sharp": "^0.34.5"
  },
  "keywords": [],
  "author": "Abenezer Atnafu",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbenezerAtnafu/better-media.git"
  },
  "homepage": "https://better-media-platform.vercel.app/",
  "bugs": {
    "url": "https://github.com/AbenezerAtnafu/better-media/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
